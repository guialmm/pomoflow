# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Python source files
*.py text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf

# Binary files — never diff/merge
*.png binary
*.jpg binary
*.ico binary

# Force diff rendering for common formats
*.md diff=markdown
*.py diff=python
